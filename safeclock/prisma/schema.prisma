generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  emailVerified DateTime?
  image        String?
  passwordHash String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  accounts     Account[]
  sessions     Session[]
  memberships  OrganizationMember[]
  timeEntries  TimeEntry[]
  timesheets   Timesheet[]
  approvedTimesheets Timesheet[] @relation("ApprovedBy")
  leaveRequests LeaveRequest[]
  approvedLeaves LeaveRequest[] @relation("LeaveApprovedBy")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("EUR")
  timezone  String   @default("Europe/Brussels")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   OrganizationMember[]
  projects  Project[]
  timesheets Timesheet[]
  leaveRequests LeaveRequest[]
}

enum OrgRole {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole      @default(EMPLOYEE)
  hourlyRate     Decimal?     @db.Decimal(10, 2)
  jobTitle       String?
  joinedAt       DateTime     @default(now())
  isActive       Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([organizationId, userId])
}

enum ProjectStatus {
  ACTIVE
  CLOSED
  ARCHIVED
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  client         String?
  status         ProjectStatus @default(ACTIVE)
  billRate       Decimal?      @db.Decimal(10, 2)
  budgetHours    Decimal?      @db.Decimal(10, 2)
  color          String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  timeEntries    TimeEntry[]
  members        ProjectMember[]
}

model ProjectMember {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@id([projectId, userId])
}

model TimeEntry {
  id          String    @id @default(cuid())
  userId      String
  projectId   String?
  description String?
  hours       Decimal   @db.Decimal(6, 2)
  date        String
  source      String    @default("timer")
  startTime   DateTime?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id])
  timesheet   Timesheet? @relation(fields: [timesheetId], references: [id])
  timesheetId String?
}

enum TimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

model Timesheet {
  id             String          @id @default(cuid())
  organizationId String
  userId         String
  monthKey       String
  status         TimesheetStatus @default(DRAFT)
  totalHours     Decimal         @db.Decimal(8, 2) @default(0)
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedById   String?
  rejectedReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy     User?           @relation("ApprovedBy", fields: [approvedById], references: [id])
  entries        TimeEntry[]
  @@unique([organizationId, userId, monthKey])
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model LeaveRequest {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  type           String
  fromDate       String
  toDate         String
  days           Int
  status         LeaveStatus  @default(PENDING)
  note           String?
  approvedById   String?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy     User?        @relation("LeaveApprovedBy", fields: [approvedById], references: [id])
}
